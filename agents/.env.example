# ─────────────────────────────────────────────────────────────
# AI Video Agent Pipeline — Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit your real .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Google Drive (download source video) ─────────────────────
# Path to your Google service account JSON key file
GOOGLE_SERVICE_ACCOUNT_JSON=agents/config/service_account.json

# OAuth2 client secret for YouTube (user-consent flow)
GOOGLE_OAUTH_CLIENT_SECRET=agents/config/client_secret.json

# Where to store the OAuth token after first consent
GOOGLE_OAUTH_TOKEN_PATH=agents/config/youtube_token.json

# ── OpenAI (TTS voiceover) ────────────────────────────────────
OPENAI_API_KEY=sk-...

# Voice to use for TTS: alloy | echo | fable | onyx | nova | shimmer
OPENAI_TTS_VOICE=nova

# ── Anthropic / Claude (caption writing) ─────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use for caption generation
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Meta / Instagram Graph API ────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# ── TikTok Content Posting API ────────────────────────────────
TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=

# ── Branding ─────────────────────────────────────────────────
# Path to your logo PNG (transparent background recommended)
LOGO_PATH=agents/assets/logo.png

# Logo position: top-left | top-right | bottom-left | bottom-right
LOGO_POSITION=bottom-right

# Logo scale relative to video width (0.0 – 1.0)
LOGO_SCALE=0.15

# ── Pipeline Behaviour ────────────────────────────────────────
# Directory for intermediate and output files
TMP_DIR=agents/tmp

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Optional: override the voiceover script (leave blank to auto-generate)
VOICEOVER_SCRIPT=

# Brand/business name used when generating captions
BRAND_NAME=FutureHome
